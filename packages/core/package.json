{
  "name": "@result-notation/core",
  "version": "0.0.1-alpha.0",
  "description": "A typed Result monad for TypeScript — ok/err, match, map, unwrap, unwrapOr",
  "homepage": "https://github.com/juliusdelta/result-notation#readme",
  "bugs": {
    "url": "https://github.com/juliusdelta/result-notation/issues"
  },
  "license": "MIT",
  "author": "result-notation contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliusdelta/result-notation.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
